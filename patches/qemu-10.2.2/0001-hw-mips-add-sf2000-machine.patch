+static uint32_t sf2000_timer_ticks(void)
+{
+    return (uint32_t)(qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) / 1000);
+}
+
+static bool sf2000_timer5_pending(void)
+{
+    uint32_t count;
+    uint32_t irq_enable = 0;
+    int64_t now = qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL);
+    unsigned i;
+
+    for (i = 0; i < ARRAY_SIZE(sf2000_regs); i++) {
+        if (sf2000_regs[i].valid && sf2000_regs[i].addr == SF2000_IRQ_ENABLE1) {
+            irq_enable = sf2000_regs[i].value;
+            break;
+        }
+    }
+
+    if (!(irq_enable & SF2000_SB_TIMER_IRQ)) {
+        return false;
+    }
+
+    /*
+     * Stock and HCRTOS both route the scheduler through external bank bit 22.
+     * Early stock boot enables that bit before programming TIMER5, then idles
+     * around CP0 Count. Keep a low-rate synthetic tick available as soon as the
+     * bank bit is enabled, and switch to compare-based behavior once TIMER5 is
+     * configured.
+     */
+    if (!(sf2000_timer5_ctrl & BIT(2)) || !(sf2000_timer5_ctrl & BIT(4))) {
+        return now >= sf2000_next_tick_ns;
+    }
+
+    count = sf2000_timer_ticks();
+    return count - sf2000_timer5_aim < 0x80000000u;
+}
+
+static void sf2000_timer_ack(void)
+{
+    sf2000_next_tick_ns = qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) + NANOSECONDS_PER_SECOND / 20;
+}
